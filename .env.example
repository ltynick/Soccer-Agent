# ============================================
# Soccer AI Agent - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的 API Key

# ---------- 必需 ----------
# 硅基流动 API Key (https://siliconflow.cn)
SILICONFLOW_API_KEY=your_siliconflow_api_key

# SerpAPI Key (https://serpapi.com)
SERPAPI_API_KEY=your_serpapi_api_key

# ---------- QQ 机器人 ----------
QQ_BOT_APP_ID=your_qq_bot_app_id
QQ_BOT_APP_SECRET=your_qq_bot_app_secret
# 关闭语音: 设为 0
QQ_BOT_SEND_VOICE=1

# ---------- 可选 ----------
# Odds API Key (https://odds-api.io)
ODDS_API_KEY=your_odds_api_key

# 切回本地 Ollama 模式: 设为 1
USE_OLLAMA=0

# ---------- 本地模型 (Ollama 模式) ----------
# Ollama 主机地址
OLLAMA_HOST=http://localhost:11434
